{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TaskState",
  "type": "object",
  "required": ["task_id", "slug", "stage", "stage_history", "fix_iterations", "branch", "pr", "depends_on", "security_hints", "blockers"],
  "properties": {
    "task_id": {"type": "string", "pattern": "^TASK-[0-9]+$"},
    "slug": {"type": "string"},
    "stage": {"type": "string", "enum": ["pending", "coding", "migrating", "reviewing", "fixing_review", "testing", "fixing_test", "merging", "done", "blocked"]},
    "stage_history": {"type": "array"},
    "fix_iterations": {"type": "object", "properties": {"review": {"type": "integer"}, "test": {"type": "integer"}}},
    "branch": {"type": ["string", "null"]},
    "pr": {"type": ["string", "null"]},
    "depends_on": {"type": "array", "items": {"type": "string"}},
    "security_hints": {"type": "array", "items": {"type": "string"}},
    "blockers": {"type": "array"}
  }
}
