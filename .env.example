# Copy this file to .env.local and fill in values for local development.
# Never commit .env.local or any file containing real secrets.

# Application
ENVIRONMENT=local

# Database (Docker Compose default)
DATABASE_URL=postgresql://user:pass@localhost:5432/mydb

# Object storage — MinIO (local) / S3 (production)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=my-bucket
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin

# Message queue — LocalStack (local) / SQS (production)
QUEUE_URL=http://localhost:4566/000000000000/my-queue
